# Copia este archivo a .env y ajusta los valores. application.yml lee estas variables
# de entorno (con valores por defecto pensados solo para desarrollo local).

# --- Base de datos ---
DB_URL=jdbc:postgresql://localhost:5432/menzo
DB_USERNAME=menzo
DB_PASSWORD=menzo
DB_POOL_SIZE=10

# --- Servidor ---
SERVER_PORT=8080

# --- JWT ---
# Genera un secreto real para producción, por ejemplo:
#   openssl rand -base64 48
JWT_SECRET=change-this-development-secret-please-override-in-prod-min-32-bytes
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30
JWT_ISSUER=menzo-api

# --- CORS ---
# Orígenes permitidos separados por coma (dominios de Expo/dev, app publicada, etc.)
CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006,exp://localhost:19000

# --- Archivos subidos (avatares, imágenes de posts/mensajes) ---
UPLOADS_DIR=./uploads
UPLOADS_PUBLIC_BASE_URL=http://localhost:8080/files

# --- Logging ---
LOG_LEVEL=INFO
